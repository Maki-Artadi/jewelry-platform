# Terraform state and secrets
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
terraform/.terraform.lock.hcl

# Ansible secrets and temp files
ansible/group_vars/all/vault.yml
ansible/*.retry
/tmp/k8s-join-command.sh
/tmp/kubeconfig

# Kubernetes secrets (never commit real secrets)
k8s/*-secret.yaml
k8s/secrets/

# Helm secrets
helm/*-secrets.yaml

# Local kubeconfig
*.kubeconfig
kubeconfig

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
